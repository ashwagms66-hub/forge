# Optional: enables AI-generated refactor drafts via OpenAI.
# Without this set, Forge automatically falls back to its local
# rule-based refactor draft generator.
OPENAI_API_KEY=

# Required for authentication (GitHub login, dashboard, analysis history).
# Generate a value with: npx auth secret
AUTH_SECRET=

# GitHub OAuth App credentials - create one at
# https://github.com/settings/developers ("New OAuth App"), with callback
# URL http://localhost:3000/api/auth/callback/github for local development.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
